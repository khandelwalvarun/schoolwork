VERACROSS_PORTAL_URL=https://portals.veracross.eu/vasantvalleyschool/parent
VERACROSS_USERNAME=your_username
VERACROSS_PASSWORD=your_password

# Scraper pacing
SCRAPER_MIN_DELAY_SEC=3.0
SCRAPER_MAX_DELAY_SEC=6.0
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Recon crawl limits
RECON_MAX_PAGES=250
RECON_MAX_DEPTH=6

# MCP HTTP transport — leave blank for localhost / Tailscale-only access.
# Set this once the host is reachable off-LAN (Cloudflare Tunnel, public IP, etc.).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Once set, /mcp and /mcp-sse return 401 unless requests include
#   Authorization: Bearer <this-token>
# Stdio (`schoolwork-mcp`) doesn't use it — that's a local trusted process.
MCP_BEARER_TOKEN=
