# Secrets
.env
.env.*
!.env.example

# Claude local settings (per-user)
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
dist/
build/

# Playwright
playwright-report/
test-results/

# Recon output (large, regenerated)
recon/output/
recon/snapshots/
recon/screenshots/
# Chromium profile cache — per-machine, can be 100s of MB
recon/user-data/
recon/storage_state.json

# Everything runtime under data/ (SQLite DB, attachments, spellbee lists,
# storage_state, creds, ui prefs). None of it belongs in git. Seed syllabus
# JSONs + their .cache PDFs are allowlisted below.
data/*
!data/syllabus/
data/syllabus/*
!data/syllabus/.gitkeep
!data/syllabus/*.json
!data/syllabus/.cache/
data/syllabus/.cache/*
!data/syllabus/.cache/*.pdf
tmp-login-debug/
tmp-probe.py

# SQLite WAL/SHM files (transient, never commit)
*.db-wal
*.db-shm

# DB
*.db
*.sqlite
*.sqlite3

# Node
node_modules/
frontend/node_modules/
frontend/dist/
frontend/tsconfig.tsbuildinfo

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
