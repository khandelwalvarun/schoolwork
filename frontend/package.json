{
  "name": "parent-cockpit-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names vite,tls -c blue,green \"vite\" \"node tls-proxy.cjs\"",
